# Built application files
*.apk
*.aab
*.ap_
*.aab

# Files for the ART/Dalvik VM
*.dex

# Generated files
bin/
gen/
out/
build/

# Gradle files
.gradle/
gradle-app.setting

# Local configuration file
local.properties

# Android Studio
*.iml
.idea/
.DS_Store
captures/

# Keystore files
*.jks
*.keystore

# External native build folder generated in Android Studio 2.2 and later
.externalNativeBuild
.cxx/

# Firebase config (decoded from GitHub secret in CI)
app/google-services.json

# Kotlin compiler cache
.kotlin/

# JVM crash logs
hs_err_pid*.log
replay_pid*.log

# Bash crash dumps
bash.exe.stackdump

# Node (screenshot composites)
node_modules/

# Firebase emulator logs
firebase-debug.log
firestore-debug.log

# Claude Code
.claude/*
!.claude/agents/
